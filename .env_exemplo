# ============================================================================
# 🔐 API de Autenticação com JWT - Arquivo de Configuração de Ambiente
# ============================================================================
#
# INSTRUÇÕES DE USO:
# 1. Faça uma cópia deste arquivo e renomeie para: .env
# 2. Atualize os valores de exemplo com seus próprios valores
# 3. ⚠️ NUNCA comite o arquivo .env no repositório (já está em .gitignore)
# 4. Compartilhe este arquivo (.env_exemplo) com outros desenvolvedores
#
# ============================================================================
# 1️⃣ AMBIENTE DE EXECUÇÃO
# ============================================================================

# Define o ambiente: 'development' | 'production'
# - development: Mostra stack traces de erro (útil para debugging)
# - production: Oculta stack traces (mais seguro)
NODE_ENV=development

# ============================================================================
# 2️⃣ CONFIGURAÇÃO DO SERVIDOR
# ============================================================================

# Porta na qual o servidor irá rodar
# Exemplo: 3000, 5000, 8080, etc.
PORT=3000

# ============================================================================
# 3️⃣ SEGREDOS CRIPTOGRÁFICOS - ⚠️ MUDAR EM PRODUÇÃO ⚠️
# ============================================================================

# 🔑 Chave Secreta para Assinatura de Access Tokens (15 minutos)
# - Comprimento mínimo: 32 caracteres hexadecimais (64 caracteres)
# - Deve ser diferente do JWT_REFRESH_SECRET
# - Gerador on-line: https://www.random.org/cgi-bin/randbytes?nbytes=32&format=h
# - Ou: openssl rand -hex 32 (Linux/macOS)
# - Ou: [System.Convert]::ToBase64String((1..32 | ForEach-Object { [byte](Get-Random -Maximum 256) })) (PowerShell)
# 
# ⚠️ IMPORTANTE:
# - Em PRODUÇÃO: Use uma chave muito forte e aleatória
# - Nunca revele ou compartilhe esta chave
# - Use um gerenciador de segredos (AWS Secrets Manager, HashiCorp Vault, etc.)
#
# Valor de teste (NÃO use em produção):
JWT_ACCESS_SECRET=sua_chave_super_forte_para_access_token_dev_123456789012345

# 🔑 Chave Secreta para Assinatura de Refresh Tokens (7 dias)
# - Mesmas recomendações do JWT_ACCESS_SECRET
# - DEVE SER DIFERENTE do JWT_ACCESS_SECRET
#
# Valor de teste (NÃO use em produção):
JWT_REFRESH_SECRET=sua_outra_chave_super_forte_para_refresh_token_dev_987654321

# ============================================================================
# 4️⃣ EXPIRAÇÃO DOS TOKENS
# ============================================================================

# Tempo de expiração do Access Token
# Formatos aceitos: 
#   - Números com unidade: "15m" (minutos), "1h" (hora), "7d" (dias)
#   - Segundos: "900" (15 minutos em segundos)
# 
# Recomendação: Manter curto (15m a 1h) para segurança
JWT_ACCESS_EXPIRATION=15m

# Tempo de expiração do Refresh Token
# Formatos aceitos: mesmos do JWT_ACCESS_EXPIRATION
# 
# Recomendação: Usar um tempo maior (7d a 30d) para conveniência do usuário
JWT_REFRESH_EXPIRATION=7d

# ============================================================================
# COMO USAR ESTE ARQUIVO
# ============================================================================
#
# PASSO 1: Copiar este arquivo
#   $ cp .env_exemplo .env
#
# PASSO 2: Editar o arquivo .env com seus valores seguros
#   - Gere novas chaves usando os comandos acima
#   - Defina o NODE_ENV apropriado (development/production)
#   - Defina a PORT desejada
#
# PASSO 3: Carregar automaticamente (dotenv faz isso)
#   - O arquivo .env será carregado automaticamente ao iniciar a aplicação
#   - As variáveis estarão disponíveis em process.env
#
# PASSO 4: Verificar se está funcionando
#   $ npm run dev
#   # Você deve ver: ✓ Variáveis de ambiente carregadas com sucesso
#
# ============================================================================
# GERADOR DE CHAVES SEGURAS - ESCOLHA SEU SISTEMA OPERACIONAL
# ============================================================================
#
# 🐧 Linux / macOS:
#   $ openssl rand -hex 32
#   $ openssl rand -hex 32
#
# 🪟 Windows PowerShell:
#   > $bytes = New-Object Byte[] 32
#   > (New-Object Random).NextBytes($bytes)
#   > [Convert]::ToHexString($bytes)
#   
#   OU (mais simples):
#   > [System.Convert]::ToBase64String((1..32 | % { [byte](Get-Random -Maximum 256) }))
#
# ============================================================================
# CHECKLIST DE SEGURANÇA
# ============================================================================
#
# Antes de fazer deploy em produção:
# ☐ JWT_ACCESS_SECRET e JWT_REFRESH_SECRET são chaves aleatórias fortes?
# ☐ As chaves têm pelo menos 32 caracteres?
# ☐ NODE_ENV está definido como "production"?
# ☐ O arquivo .env foi adicionado ao .gitignore?
# ☐ Você NÃO commitou o arquivo .env?
# ☐ Você está usando um gerenciador de segredos (AWS, Vault, etc.)?
# ☐ As chaves são diferentes para cada ambiente (dev, staging, prod)?
#
# ============================================================================
